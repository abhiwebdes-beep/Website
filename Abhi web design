<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Abhi Web Design | Digital Excellence</title>
    <style>
        :root {
            --primary-color: #3b82f6; 
            --bg-main: #050505; 
            --bg-card: #121212; 
            --text-main: #ffffff;
            --text-muted: #a3a3a3;
            --border-color: #262626;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-main);
            line-height: 1.6;
        }

        /* Animations */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Navigation */
        nav {
            background-color: rgba(5, 5, 5, 0.9);
            backdrop-filter: blur(10px);
            padding: 1.5rem 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border-color);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-main);
            text-decoration: none;
            letter-spacing: 1px;
        }

        .logo span {
            color: var(--primary-color);
        }

        .nav-links a {
            margin-left: 2rem;
            text-decoration: none;
            color: var(--text-muted);
            font-weight: 500;
            transition: color 0.3s ease;
        }

        .nav-links a:hover {
            color: var(--text-main);
        }

        /* Hero Section */
        .hero {
            height: 80vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 0 20px;
            animation: fadeIn 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        }

        .hero h1 {
            font-size: 4rem;
            margin-bottom: 1.2rem;
            line-height: 1.1;
            font-weight: 800;
        }

        .hero p {
            font-size: 1.25rem;
            color: var(--text-muted);
            max-width: 600px;
            margin-bottom: 2.5rem;
        }

        .btn {
            padding: 14px 36px;
            background-color: var(--primary-color);
            color: var(--text-main);
            text-decoration: none;
            border-radius: 4px;
            font-weight: bold;
            font-size: 1.1rem;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
        }

        .btn:hover {
            background-color: #2563eb;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(59, 130, 246, 0.5);
        }

        /* Portfolio Grid */
        .portfolio-section {
            padding: 6rem 5%;
            background-color: var(--bg-main);
        }

        .portfolio-section h2 {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 4rem;
            font-weight: 700;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2.5rem;
        }

        .card {
            background: var(--bg-card);
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid var(--border-color);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            cursor: pointer;
        }

        .card:hover {
            transform: scale(1.03) translateY(-10px);
            border-color: var(--primary-color);
            box-shadow: 0 10px 30px rgba(59, 130, 246, 0.15);
        }

        /* Image Container & Hover Effect */
        .card-img-container {
            height: 220px;
            width: 100%;
            overflow: hidden;
            border-bottom: 1px solid var(--border-color);
        }

        .card-img-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .card:hover .card-img-container img {
            transform: scale(1.1);
        }

        .card-content {
            padding: 1.8rem;
        }

        .card-content h3 {
            margin-bottom: 0.8rem;
            color: var(--text-main);
            font-size: 1.4rem;
        }

        .card-content p {
            color: var(--text-muted);
            font-size: 1rem;
            line-height: 1.5;
        }

        /* Footer / Contact */
        footer {
            background-color: var(--bg-card);
            color: var(--text-main);
            text-align: center;
            padding: 5rem 20px;
            border-top: 1px solid var(--border-color);
        }

        footer h2 {
            margin-bottom: 1rem;
            font-size: 2rem;
        }

        footer p {
            color: var(--text-muted);
            margin-bottom: 2rem;
        }

        footer a {
            color: var(--primary-color);
            text-decoration: none;
            font-size: 1.5rem;
            font-weight: bold;
            display: inline-block;
            transition: color 0.3s ease;
        }

        footer a:hover {
            color: #60a5fa;
        }
    </style>
</head>
<body>

    <!-- Navigation -->
    <nav>
        <a href="#home" class="logo">Abhi <span>Web Design</span></a>
        <div class="nav-links">
            <a href="#home">Home</a>
            <a href="#portfolio">Portfolio</a>
            <a href="mailto:contact@abhiwebdesign.com">Contact</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <header id="home" class="hero">
        <h1>Building Digital Experiences</h1>
        <p>We create beautiful, high-converting websites tailored specifically for local businesses, contractors, and service professionals.</p>
        <a href="#portfolio" class="btn">View Our Work</a>
    </header>

    <!-- Portfolio Grid -->
    <section id="portfolio" class="portfolio-section">
        <h2>Our Recent Work</h2>
        
        <div class="grid">
            <!-- Project 1: Tech / SaaS -->
            <div class="card">
                <div class="card-img-container">
                    <img src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&w=800&q=80" alt="SaaS Dashboard Project">
                </div>
                <div class="card-content">
                    <h3>Tech Platform Design</h3>
                    <p>A clean, responsive dashboard designed for complex data visualization and user management.</p>
                </div>
            </div>

            <!-- Project 2: Retail / E-commerce -->
            <div class="card">
                <div class="card-img-container">
                    <img src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?auto=format&fit=crop&w=800&q=80" alt="E-commerce Store Project">
                </div>
                <div class="card-content">
                    <h3>Modern E-Commerce</h3>
                    <p>An image-driven layout optimized for fast loading, easy navigation, and high conversion rates.</p>
                </div>
            </div>

            <!-- Project 3: Real Estate / Architecture -->
            <div class="card">
                <div class="card-img-container">
                    <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=800&q=80" alt="Real Estate Project">
                </div>
                <div class="card-content">
                    <h3>Luxury Real Estate</h3>
                    <p>A visually engaging platform designed to showcase high-resolution architectural imagery.</p>
                </div>
            </div>

            <!-- Project 4: Fitness / Health -->
            <div class="card">
                <div class="card-img-container">
                    <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?auto=format&fit=crop&w=800&q=80" alt="Fitness Studio Project">
                </div>
                <div class="card-content">
                    <h3>Fitness & Wellness</h3>
                    <p>A high-energy, mobile-first website built to capture leads and schedule classes seamlessly.</p>
                </div>
            </div>

            <!-- Project 5: Culinary / Hospitality -->
            <div class="card">
                <div class="card-img-container">
                    <img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&w=800&q=80" alt="Restaurant Web Design">
                </div>
                <div class="card-content">
                    <h3>Fine Dining Experience</h3>
                    <p>An elegant, interactive digital menu and reservation system tailored to the hospitality industry.</p>
                </div>
            </div>

            <!-- Project 6: Creative / Agency -->
            <div class="card">
                <div class="card-img-container">
                    <img src="https://images.unsplash.com/photo-1550745165-9bc0b252726f?auto=format&fit=crop&w=800&q=80" alt="Creative Agency Project">
                </div>
                <div class="card-content">
                    <h3>Creative Portfolio</h3>
                    <p>A bold, experimental site architecture designed to establish brand authority and showcase creativity.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer / Contact -->
    <footer id="contact">
        <h2>Ready to start your project?</h2>
        <p>Reach out directly via email to discuss your next website.</p>
        <a href="mailto:abhi.webdes@gmail.com">abhi.webdes@gmail.com</a>
    </footer>

</body>
</html>


